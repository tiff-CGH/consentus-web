---
interface Props {
  href: string;
  title: string;
  description: string;
  clinician: string;
  gmcNumber: string;
  lastReviewed: string; // ISO date or human-readable
  variant?: 'default' | 'featured';
}

const {
  href,
  title,
  description,
  clinician,
  gmcNumber,
  lastReviewed,
  variant = 'default',
} = Astro.props;

const reviewedFormatted = (() => {
  const d = new Date(lastReviewed);
  if (Number.isNaN(d.getTime())) return lastReviewed;
  return d.toLocaleDateString('en-GB', { month: 'long', year: 'numeric' });
})();
---

<a href={href} class:list={['procedure-card', `variant-${variant}`]}>
  <div class="thumb" aria-hidden="true">
    <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor">
      <path d="M8 5v14l11-7z" />
    </svg>
  </div>
  <div class="body">
    <h3 class="title">{title}</h3>
    <p class="description">{description}</p>
    <div class="meta">
      <span>{clinician} · GMC {gmcNumber}</span>
      <span class="meta-sep" aria-hidden="true">·</span>
      <span>Reviewed {reviewedFormatted}</span>
    </div>
  </div>
</a>

<style>
  .procedure-card {
    display: flex;
    gap: 1.25rem;
    padding: 1.5rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.18s ease, transform 0.18s ease;
    align-items: flex-start;
  }

  .procedure-card:hover {
    border-color: var(--color-border-strong);
    transform: translateY(-1px);
  }

  .procedure-card.variant-featured {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
  }

  .thumb {
    width: 180px;
    aspect-ratio: 16 / 9;
    background: var(--color-text);
    border-radius: 4px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-bg);
    position: relative;
  }

  .thumb::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at center, transparent 30%, rgba(0,0,0,0.25) 90%);
    border-radius: 4px;
    pointer-events: none;
  }

  .thumb svg {
    background: var(--color-bg);
    color: var(--color-text);
    border-radius: 50%;
    padding: 10px;
    width: 38px;
    height: 38px;
    margin-left: 2px;
    z-index: 1;
  }

  .body {
    flex: 1;
    min-width: 0;
  }

  .title {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--color-text);
    margin-bottom: 0.4rem;
    letter-spacing: -0.01em;
    font-variation-settings: 'opsz' 22;
  }

  .description {
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--color-text-muted);
    margin-bottom: 0.85rem;
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    font-size: 0.75rem;
    color: var(--color-text-faint);
    align-items: center;
  }

  .meta-sep {
    color: var(--color-border-strong);
  }

  @media (max-width: 640px) {
    .procedure-card {
      flex-direction: column;
      gap: 1rem;
    }
    .thumb {
      width: 100%;
    }
  }
</style>
