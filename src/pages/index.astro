---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProcedureCard from '../components/ProcedureCard.astro';
import { getCollection } from 'astro:content';

// Get the most recently published, non-draft procedure for the hero feature.
// In dev, draft entries are visible by default; in production they're hidden.
const all = await getCollection('procedures');
const featured = all
  .filter((entry) => !entry.data.draft || import.meta.env.DEV)
  .sort((a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime())[0];
---

<BaseLayout
  title="Consentus"
  description="A free library of surgical procedure videos and FAQs, made by named UK consultants. Watch before your consultation. Ask better questions. Decide with confidence."
>
  <!-- Hero -->
  <section class="hero container">
    <div class="hero-inner fade-in">
      <h1>Informed consent, properly explained.</h1>
      <p class="hero-sub">
        A free library of surgical procedure videos and FAQs, made by named UK consultants.
        Watch before your consultation. Ask better questions. Decide with confidence.
      </p>
      <div class="hero-actions">
        <a href="/procedures" class="btn btn-primary">Browse procedures</a>
        <a href="/for-clinicians" class="btn btn-secondary">For clinicians →</a>
      </div>
    </div>
  </section>

  <!-- Featured procedure -->
  {featured && (
    <section class="featured">
      <div class="container">
        <p class="eyebrow">Latest procedure</p>
        <div class="featured-card-wrap">
          <ProcedureCard
            href={`/procedures/${featured.id}`}
            title={featured.data.title}
            description={featured.data.summary}
            clinician={featured.data.clinician}
            gmcNumber={featured.data.gmcNumber}
            lastReviewed={featured.data.lastReviewed}
            variant="featured"
          />
        </div>
      </div>
    </section>
  )}

  <!-- How it works -->
  <section class="how container">
    <div class="how-grid">
      <div class="how-intro">
        <p class="eyebrow">How Consentus works</p>
        <h2>Three steps. No marketing.</h2>
      </div>
      <div class="how-steps">
        <div class="step">
          <p class="step-number">01</p>
          <h3>Find your procedure</h3>
          <p>Search the library by procedure name. Each page is written and reviewed by a named UK consultant in the relevant specialty.</p>
        </div>
        <div class="step">
          <p class="step-number">02</p>
          <h3>Watch before your appointment</h3>
          <p>A short video walks you through what the operation involves, what to expect, the main risks, and the realistic alternatives.</p>
        </div>
        <div class="step">
          <p class="step-number">03</p>
          <h3>Bring better questions</h3>
          <p>Use the structured FAQ to prepare. The fifteen-minute consultation goes further when you arrive already knowing what you don't know.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- For clinicians teaser -->
  <section class="clinician-teaser">
    <div class="container clinician-teaser-inner">
      <div>
        <p class="eyebrow">For clinicians</p>
        <h2>Built with practising surgeons.</h2>
        <p class="prose">
          Consentus is a clinician-led library. We handle production end-to-end —
          you bring the expertise. If you'd like to author a procedure in your
          specialty, we'd like to talk.
        </p>
      </div>
      <div class="clinician-cta">
        <a href="/for-clinicians" class="btn btn-secondary">Get involved →</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding-top: var(--space-2xl);
    padding-bottom: var(--space-xl);
  }

  .hero-inner {
    max-width: 36rem;
  }

  .hero h1 {
    margin-bottom: 1.25rem;
  }

  .hero-sub {
    font-size: 1.125rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    margin-bottom: 2rem;
    max-width: 32rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .featured {
    background: var(--color-bg-secondary);
    padding: var(--space-xl) 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .featured .eyebrow {
    margin-bottom: 1rem;
  }

  .featured-card-wrap {
    max-width: 56rem;
  }

  .how {
    padding-top: var(--space-2xl);
    padding-bottom: var(--space-xl);
  }

  .how-grid {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 4rem;
    align-items: start;
  }

  .how-intro h2 {
    margin-top: 0.5rem;
  }

  .how-steps {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .step {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1.25rem 1.75rem;
    align-items: baseline;
    padding-bottom: 1.75rem;
    border-bottom: 1px solid var(--color-border);
  }

  .step:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }

  .step-number {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    color: var(--color-accent);
    font-weight: 500;
    grid-row: 1 / 3;
    line-height: 1;
    font-variation-settings: 'opsz' 24;
  }

  .step h3 {
    margin-bottom: 0.5rem;
  }

  .step p {
    grid-column: 2;
    font-size: 1rem;
  }

  .clinician-teaser {
    padding: var(--space-xl) 0;
    border-top: 1px solid var(--color-border);
  }

  .clinician-teaser-inner {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 3rem;
    align-items: end;
  }

  .clinician-teaser h2 {
    margin: 0.5rem 0 1rem;
  }

  .clinician-cta {
    text-align: right;
  }

  @media (max-width: 720px) {
    .how-grid,
    .clinician-teaser-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .clinician-cta {
      text-align: left;
    }
    .step {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
    .step p {
      grid-column: 1;
    }
  }
</style>
